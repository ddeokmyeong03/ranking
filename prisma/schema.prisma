generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// UNIT & ORGANIZATION
// =============================================

model Unit {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  parentId  String?
  parent    Unit?    @relation("UnitHierarchy", fields: [parentId], references: [id])
  children  Unit[]   @relation("UnitHierarchy")
  createdAt DateTime @default(now())

  members        Member[]
  cycles         DutyCycle[]
  assignments    DutyAssignment[]
  holidays       UnitHoliday[]
  allowanceRates AllowanceRate[]
}

// =============================================
// MEMBER (간부)
// =============================================

model Member {
  id               String     @id @default(cuid())
  militaryId       String     @unique
  passwordHash     String
  name             String
  rank             String
  position         String?
  commissionDate   DateTime?
  dischargeDate    DateTime?
  role             MemberRole @default(USER)
  unitId           String
  unit             Unit       @relation(fields: [unitId], references: [id])
  isActive         Boolean    @default(true)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  trustedDevices   TrustedDevice[]
  notifications    Notification[]
  assignments      DutyAssignment[]
  cycleEntries     DutyCycleMember[]
  changeListings   DutyChangeListing[]
  changeOffers     DutyChangeOffer[]
  sentRequests     DutyChangeRequest[]  @relation("Requester")
  receivedRequests DutyChangeRequest[]  @relation("RequestTarget")
}

enum MemberRole {
  UNIT_ADMIN
  USER
}

// =============================================
// TRUSTED DEVICE (자동 로그인)
// =============================================

model TrustedDevice {
  id          String   @id @default(cuid())
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  deviceToken String   @unique
  userAgent   String?
  lastUsedAt  DateTime @default(now())
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([memberId])
}

// =============================================
// DUTY CYCLE (당직 사이클)
// =============================================

model DutyCycle {
  id         String   @id @default(cuid())
  unitId     String
  unit       Unit     @relation(fields: [unitId], references: [id])
  name       String
  startDate  DateTime @db.Date
  endDate    DateTime @db.Date
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  cycleMembers DutyCycleMember[]
  assignments  DutyAssignment[]
}

model DutyCycleMember {
  id         String    @id @default(cuid())
  cycleId    String
  cycle      DutyCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  memberId   String
  member     Member    @relation(fields: [memberId], references: [id])
  sortOrder  Int
  isExcluded Boolean   @default(false)

  @@unique([cycleId, memberId])
  @@index([cycleId, sortOrder])
}

// =============================================
// HOLIDAYS (공휴일/전투휴무)
// =============================================

model UnitHoliday {
  id          String      @id @default(cuid())
  unitId      String
  unit        Unit        @relation(fields: [unitId], references: [id])
  date        DateTime    @db.Date
  type        HolidayType
  name        String?
  createdById String?
  createdAt   DateTime    @default(now())

  @@unique([unitId, date])
  @@index([unitId, date])
}

enum HolidayType {
  PUBLIC_HOLIDAY
  COMBAT_REST
}

// =============================================
// DUTY ASSIGNMENT (당직 편성)
// =============================================

model DutyAssignment {
  id               String    @id @default(cuid())
  unitId           String
  unit             Unit      @relation(fields: [unitId], references: [id])
  cycleId          String?
  cycle            DutyCycle? @relation(fields: [cycleId], references: [id])
  memberId         String
  member           Member    @relation(fields: [memberId], references: [id])
  date             DateTime  @db.Date
  dutyType         DutyType
  isSwapped        Boolean   @default(false)
  originalMemberId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  changeListings   DutyChangeListing[]
  incomingRequests DutyChangeRequest[]  @relation("TargetAssignment")
  outgoingRequests DutyChangeRequest[]  @relation("RequesterAssignment")

  @@unique([unitId, date, dutyType])
  @@index([memberId])
  @@index([unitId, date])
}

enum DutyType {
  WEEKDAY
  WEEKEND_DAY
  WEEKEND_NIGHT
}

// =============================================
// DUTY CHANGE LISTING (변경 희망 게시글)
// =============================================

model DutyChangeListing {
  id           String        @id @default(cuid())
  assignmentId String
  assignment   DutyAssignment @relation(fields: [assignmentId], references: [id])
  posterId     String
  poster       Member        @relation(fields: [posterId], references: [id])
  message      String?
  status       ListingStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  offers DutyChangeOffer[]
}

enum ListingStatus {
  OPEN
  MATCHED
  CLOSED
}

// =============================================
// DUTY CHANGE OFFER (변경 신청)
// =============================================

model DutyChangeOffer {
  id                   String      @id @default(cuid())
  listingId            String
  listing              DutyChangeListing @relation(fields: [listingId], references: [id])
  offererId            String
  offerer              Member      @relation(fields: [offererId], references: [id])
  offererAssignmentId  String
  status               OfferStatus @default(PENDING)
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
}

enum OfferStatus {
  PENDING
  APPROVED
  REJECTED
}

// =============================================
// DUTY CHANGE REQUEST (직접 변경 요청)
// =============================================

model DutyChangeRequest {
  id                      String        @id @default(cuid())
  requesterId             String
  requester               Member        @relation("Requester", fields: [requesterId], references: [id])
  requesterAssignmentId   String
  requesterAssignment     DutyAssignment @relation("RequesterAssignment", fields: [requesterAssignmentId], references: [id])
  targetMemberId          String
  targetMember            Member        @relation("RequestTarget", fields: [targetMemberId], references: [id])
  targetAssignmentId      String
  targetAssignment        DutyAssignment @relation("TargetAssignment", fields: [targetAssignmentId], references: [id])
  message                 String?
  status                  RequestStatus @default(PENDING)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// =============================================
// ALLOWANCE RATES (수당 요율)
// =============================================

model AllowanceRate {
  id            String    @id @default(cuid())
  unitId        String
  unit          Unit      @relation(fields: [unitId], references: [id])
  dutyType      DutyType
  amountKRW     Int
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime  @default(now())

  @@index([unitId, dutyType, effectiveFrom])
}

// =============================================
// NOTIFICATIONS (알림)
// =============================================

model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   Member           @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  body        String
  payload     Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([recipientId, isRead, createdAt])
}

enum NotificationType {
  DUTY_SCHEDULE_PUBLISHED
  LISTING_NEW
  LISTING_OFFER_RECEIVED
  LISTING_OFFER_APPROVED
  LISTING_OFFER_REJECTED
  REQUEST_RECEIVED
  REQUEST_APPROVED
  REQUEST_REJECTED
  SWAP_COMPLETED
}
